# ============================================
# NeuroSent Environment Variables
# ============================================
# Copy this file to .env and fill in real values:
#   copy .env.example .env
#
# NEVER commit the .env file to version control!
# ============================================

# Flask secret key (generate a strong random one)
# Python: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_use_a_strong_random_secret

# SMTP Configuration (Gmail App Password)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password_here
MAIL_DEFAULT_SENDER=your_email@gmail.com

# OpenRouter API (Primary Sentiment Engine)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-001
